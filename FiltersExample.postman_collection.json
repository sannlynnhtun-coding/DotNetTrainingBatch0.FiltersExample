							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.include(\"Received: Postman\");",
							"});",
							"pm.test(\"Check ResponseTimeFilter Header\", function () {",
							"    pm.response.to.have.header(\"X-Action-Duration-ms\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
